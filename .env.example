VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Google Calendar OAuth (Schedule module)
# Public — goes in the client bundle:
VITE_GOOGLE_CLIENT_ID=418424666985-xxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# Server-only (Vercel env, NOT in the bundle):
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
# Server-only: service role key — lets the edge function write google_tokens / events:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
